  {
    "name": "IntelligenceService.GetIPIocTag",
    "comment": "获取 IP 情报标签",
    "args": {
      "ip": {
        "type": "string",
        "optional": false,
        "comment": "IP 地址"
      }
    },
    "reply": {}
