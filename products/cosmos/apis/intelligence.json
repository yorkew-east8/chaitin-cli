[
  {
    "name": "IntelligenceService.GetIPIocList",
    "comment": "获取 IP 情报列表 / 查询 IP 是否存在情报（复杂查询参数传 JSON 数组）",
    "args": {
      "count": {
        "type": "integer",
        "optional": true,
        "comment": "每页数量"
      },
      "offset": {
        "type": "integer",
        "optional": true,
        "comment": "偏移量"
      },
      "ip": {
        "type": "string",
        "optional": true,
        "comment": "IP 地址过滤 (JSON, 如: [{\"oper\":\"=\",\"target\":\"1.1.1.1\"}]       // oper: =,!=,like,not like,reg,is_null)",
        "queryType": "StringQuery"
      },
      "ioc_src": {
        "type": "string",
        "optional": true,
        "comment": "情报来源: cosmos_analyze万象分析 manual_add人工新增 chaitin_shared长亭共享 aliyun阿里云 threatbook微步 tianji平台情报 safe_point长亭情报库导入 (JSON, 如: [{\"oper\":\"like\",\"target\":\"manual_add\"}]       // oper: =,!=,like,not like,reg,is_null)",
        "queryType": "StringQuery"
      },
      "severity": {
        "type": "string",
        "optional": true,
        "comment": "威胁等级: 0信息/无威胁 1低危 2中危 3高危 4严重/超危 (JSON, 如: [{\"oper\":\"=\",\"target\":3}]             // oper: =,!=,>,>=,<,<=,is_null)",
        "queryType": "IntQuery"
      },
      "confidence_level": {
        "type": "string",
        "optional": true,
        "comment": "可信度等级: 2低可信[0,60) 3一定可信[60,85) 4高可信[85,100] (JSON, 如: [{\"oper\":\"=\",\"target\":3}]             // oper: =,!=,>,>=,<,<=,is_null)",
        "queryType": "IntQuery"
      },
      "updated_at": {
        "type": "string",
        "optional": true,
        "comment": "更新时间 (JSON, 如: [{\"oper\":\"in\",\"target\":\"0-1781501714000\"}]，或直接传毫秒时间戳范围 0-1781501714000)",
        "queryType": "TimeQuery"
      },
      "invalid_date": {
        "type": "string",
        "optional": true,
        "comment": "失效时间 (JSON, 如: [{\"oper\":\">=\",\"target\":\"1781501714\"}]；范围查询可传 0-1781501714000)",
        "queryType": "TimeQuery"
      },
      "is_hit": {
        "type": "string",
        "optional": true,
        "comment": "是否命中: 1命中 2未命中 (JSON, 如: [{\"oper\":\"=\",\"target\":1}]             // oper: =,!=,>,>=,<,<=,is_null)",
        "queryType": "IntQuery"
      },
      "is_block": {
        "type": "string",
        "optional": true,
        "comment": "是否封禁: 1封禁中 2未封禁 (JSON, 如: [{\"oper\":\"=\",\"target\":1}]             // oper: =,!=,>,>=,<,<=,is_null)",
        "queryType": "IntQuery"
      },
      "judgments": {
        "type": "string",
        "optional": true,
        "comment": "威胁标签 (JSON, 如: [{\"oper\":\"like\",\"target\":\"Scanner\"}]       // oper: =,!=,like,not like,reg,is_null)",
        "queryType": "StringQuery"
      },
      "tags": {
        "type": "string",
        "optional": true,
        "comment": "信息标签 (JSON, 如: [{\"oper\":\"like\",\"target\":\"IDC\"}]       // oper: =,!=,like,not like,reg,is_null)",
        "queryType": "StringQuery"
      },
      "state": {
        "type": "string",
        "optional": true,
        "comment": "情报状态: 1有效 2无效 0未知 (JSON, 如: [{\"oper\":\"=\",\"target\":1}]             // oper: =,!=,>,>=,<,<=,is_null)",
        "queryType": "IntQuery"
      }
    },
    "reply": {}
  },
  {
