  {
    "name": "IntelligenceService.GetIPIocInfo",
    "comment": "获取 IP 情报详情（主情报信息）",
    "args": {
      "ip": {
        "type": "string",
        "optional": false,
        "comment": "IP 地址"
      }
    },
    "reply": {}
