[
  {
    "name": "LogService.SearchLogList",
    "comment": "获取日志列表（安全日志检索；time_range_start/time_range_end 使用毫秒时间戳）",
    "args": {
      "count": {
        "type": "integer",
        "optional": true,
        "comment": "每页数量"
      },
      "offset": {
        "type": "integer",
        "optional": true,
        "comment": "偏移量"
      },
      "time_range_start": {
        "type": "integer",
        "optional": false,
        "comment": "开始时间（毫秒时间戳）"
      },
      "time_range_end": {
        "type": "integer",
        "optional": false,
        "comment": "结束时间（毫秒时间戳）"
      },
      "keyword": {
        "type": "string",
        "optional": true,
        "typeclass": "array",
        "comment": "关键字搜索"
      },
      "filter": {
        "type": "string",
        "optional": true,
        "comment": "过滤条件（RawMessage JSON）",
        "queryType": "JSON"
      },
      "advanced_query": {
        "type": "string",
        "optional": true,
        "comment": "高级查询条件（AdvancedQuery JSON）",
        "queryType": "JSON"
      },
      "condition_query": {
        "type": "string",
        "optional": true,
        "comment": "组合查询条件（ConditionQuery JSON）",
        "queryType": "JSON"
      },
      "organization": {
        "type": "string",
        "optional": true,
        "comment": "组织机构过滤（UintQuery JSON，如: [{\"oper\":\"=\",\"target\":1}]）",
        "queryType": "UintQuery"
      },
      "fall": {
        "type": "bool",
        "optional": true,
        "comment": "失陷过滤: true失陷 false未失陷"
      },
      "attack_chain_phase": {
        "type": "integer",
        "optional": true,
        "typeclass": "array",
        "comment": "攻击链阶段: -1未知 1侦查 2入侵 3载荷投递 4命令与控制 5内网横向 6达成目标 7痕迹清理"
      }
    },
    "reply": {}
  },
