      },
      "found_time": {
        "type": "string",
        "optional": true,
        "comment": "发现时间 (TimeQuery JSON 或简写 startMs-endMs)",
        "queryType": "TimeQuery"
      },
      "verify_time": {
        "type": "string",
        "optional": true,
        "comment": "验证时间 (TimeQuery JSON 或简写 startMs-endMs)",
        "queryType": "TimeQuery"
      },
      "fix_time": {
        "type": "string",
        "optional": true,
        "comment": "修复时间 (TimeQuery JSON 或简写 startMs-endMs)",
        "queryType": "TimeQuery"
      },
      "recheck_time": {
        "type": "string",
        "optional": true,
        "comment": "复测时间 (TimeQuery JSON 或简写 startMs-endMs)",
        "queryType": "TimeQuery"
      },
      "close_time": {
        "type": "string",
        "optional": true,
        "comment": "闭环时间 (TimeQuery JSON 或简写 startMs-endMs)",
        "queryType": "TimeQuery"
      },
      "is_match_vuln": {
        "type": "string",
