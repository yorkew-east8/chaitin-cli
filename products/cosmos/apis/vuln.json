        "comment": "漏洞 ID (JSON, 如: [{\"oper\":\"=\",\"target\":68}])",
        "queryType": "UintQuery"
      },
      "organization_id": {
        "type": "string",
        "optional": true,
        "comment": "组织机构 ID (JSON, 如: [{\"oper\":\"=\",\"target\":1}])",
        "queryType": "UintQuery"
      },
      "name": {
        "type": "string",
        "optional": true,
        "comment": "漏洞名称 (JSON, 如: [{\"oper\":\"like\",\"target\":\"CVE\"}])",
        "queryType": "StringQuery"
      },
      "port": {
        "type": "string",
        "optional": true,
